# Tatá House — variáveis de ambiente
# Copie este arquivo para .env.local (no seu computador) ou configure os mesmos
# nomes na Vercel (Settings → Environment Variables).
#
# O Supabase é OPCIONAL: sem estas variáveis, o app funciona 100% em localStorage.

# URL do projeto Supabase (Supabase → Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave pública do Supabase — aceita a "anon" (eyJ...) ou a "publishable" (sb_publishable_...)
# (Supabase → Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-publica

# Opcional: separa os dados por unidade/loja (default: tata-house)
# NEXT_PUBLIC_TATA_ESPACO=tata-house

# ── Inteligência (IA) ─────────────────────────────────────────────────
# RECOMENDADO: rode a IA por uma Edge Function (a chave fica no SERVIDOR, fora
# do bundle do navegador). Veja supabase/functions/llm/index.ts.
#   1) supabase functions deploy llm --no-verify-jwt
#   2) supabase secrets set GEMINI_API_KEY=AIza...   (e/ou GROQ_API_KEY=...)
#   3) ative aqui e NÃO use as chaves NEXT_PUBLIC_* de IA abaixo:
# NEXT_PUBLIC_IA_EDGE=1
#
# ALTERNATIVA (menos segura): chaves direto no client. Ficam VISÍVEIS no
# navegador — use só chaves gratuitas/limitadas (ex.: Gemini AI Studio).
# NEXT_PUBLIC_GEMINI_API_KEY=AIza...
# NEXT_PUBLIC_GROQ_KEY=gsk_...
